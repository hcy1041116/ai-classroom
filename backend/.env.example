# =============================================================================
# SELf-Corner 環境變數範本
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
# =============================================================================


# =============================================================================
# LiveKit 連線設定
# 至 https://cloud.livekit.io 建立專案後取得
# =============================================================================
LIVEKIT_URL=wss://your-project-id.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret


# =============================================================================
# OpenAI API 金鑰
# 需有 Realtime API（gpt-4o-realtime-preview）存取權限
# 至 https://platform.openai.com/api-keys 取得
# =============================================================================
OPENAI_API_KEY=sk-proj-your_openai_api_key


# =============================================================================
# 資料庫連線字串
# 格式：postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# 密碼含特殊字元（如 @）需做 URL encode，例如 @ → %40
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/self_corner


# =============================================================================
# JWT 認證金鑰
# 建議使用 secrets.token_hex(32) 產生，請勿使用簡單字串
# 此值需在每次部署中保持固定，改動後所有使用者的 token 將失效
# =============================================================================
JWT_SECRET_KEY=your_random_secret_key_at_least_32_characters

# =============================================================================
# Google OAuth
# https://console.cloud.google.com/apis/credentials
# =============================================================================
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:8080

# =============================================================================
# Email SMTP(Gmail App Password)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=SELf-Corner


# =============================================================================
# AI 模型設定（選填，有預設值）
# =============================================================================

# 教練分析與回顧對話使用的模型（預設 gpt-4o）
COACH_MODEL=gpt-4o


# =============================================================================
# 伺服器設定（選填，有預設值）
# =============================================================================

# 執行環境：development | production
ENV=development

# FastAPI 監聽位址（0.0.0.0 表示監聽所有介面）
API_HOST=0.0.0.0

# FastAPI 監聽埠號
API_PORT=8000
